0\" r=\"3\"></circle></svg>Marco Business Center</div></div><div class=\"w-20 h-20 border-[3px] border-foreground rounded-2xl opacity-10 p-1.5 flex flex-wrap gap-1.5 hidden sm:flex\"><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div></div></div><div class=\"mt-auto flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6\"><div class=\"font-mono text-foreground/40 font-bold text-xl tracking-wider\">GENERAL<br/>ADMISSION</div><a class=\"doodle-border doodle-shadow-active bg-sw-blue text-white font-heading font-bold text-2xl px-10 py-4 rounded-full hover:bg-sw-navy hover:scale-105 transition-all w-full sm:w-auto cursor-pointer text-center inline-block\" href=\"/constanta#signup\">Join now</a></div></div></div></div><div class=\"md:relative w-full max-w-3xl md:-ml-56 z-20\" style=\"transform:translateX(-80px) translateY(-15px) scale(0.92)\"><div class=\"doodle-border doodle-shadow bg-white rounded-[2.5rem] overflow-hidden flex flex-col md:flex-row relative group w-full h-full\"><div class=\"bg-sw-navy text-white p-10 flex flex-col justify-center items-center md:w-[32%] relative border-b-4 md:border-b-0 md:border-r-[4px] border-dashed border-foreground/30\"><div class=\"absolute top-[-24px] right-[-24px] w-12 h-12 bg-sw-blue-washed rounded-full border-[3px] border-foreground z-20 hidden md:block\"></div><div class=\"absolute bottom-[-24px] right-[-24px] w-12 h-12 bg-sw-blue-washed rounded-full border-[3px] border-foreground z-20 hidden md:block\"></div><span class=\"font-heading font-black text-7xl md:text-8xl tracking-tighter mb-2\">24-26</span><span class=\"font-heading font-bold text-3xl md:text-4xl uppercase tracking-widest\">April</span></div><div class=\"p-10 md:p-14 md:w-[68%] flex flex-col justify-between relative bg-[#fdfdfd]\"><div class=\"flex justify-between items-start mb-16\"><div><h3 class=\"font-heading font-black text-5xl md:text-6xl mb-4\">Bucharest</h3><div class=\"flex items-center gap-3 text-foreground/70 font-medium text-xl md:text-2xl\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg>Nova</div></div><div class=\"w-20 h-20 border-[3px] border-foreground rounded-2xl opacity-10 p-1.5 flex flex-wrap gap-1.5 hidden sm:flex\"><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div><div class=\"w-4 h-4 bg-foreground rounded-sm\"></div></div></div><div class=\"mt-auto flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6\"><div class=\"font-mono text-foreground/40 font-bold text-xl tracking-wider\">GENERAL<br/>ADMISSION</div><a class=\"doodle-border doodle-shadow-active bg-sw-blue text-white font-heading font-bold text-2xl px-10 py-4 rounded-full hover:bg-sw-navy hover:scale-105 transition-all w-full sm:w-auto cursor-pointer text-center inline-block\" href=\"https://startupweekendbucharest.com/\">Join now</a></div></div></div></div></div></div></section><section class=\"w-full max-w-7xl mx-auto px-6 py-24 md:py-32 relative\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div class=\"flex flex-col relative z-10\"><div class=\"inline-block mb-4\"><span class=\"font-hand text-xl md:text-2xl text-sw-blue border-2 border-foreground rounded-full px-4 py-1 rotate-[-3deg] inline-block bg-white doodle-shadow-active\">The big question</span></div><h2 class=\"font-heading font-bold text-5xl md:text-6xl lg:text-7xl leading-tight mb-8\">What is <br/><span class=\"text-sw-blue\">Startup Weekend</span><br/>Romania?</h2><p class=\"font-medium text-lg md:text-xl text-foreground/80 leading-relaxed mb-10 max-w-lg\">Startup Weekend Romania is an electrifying 54-hour hackathon-style sprint where startup enthusiasts (from developers to creatives) pitch ideas, form teams, and build their first minimum viable product.</p></div><div class=\"relative h-full min-h-[400px] flex items-center justify-center lg:justify-end\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-sw-blue-washed rounded-full blur-3xl opacity-50 -z-10\"></div><div class=\"relative w-full max-w-md doodle-border doodle-shadow bg-[#FFD166] rounded-xl p-10 rotate-[4deg] transform hover:rotate-0 transition-transform duration-500 z-10\"><div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-sw-navy rounded-full border-2 border-foreground shadow-[2px_2px_0px_#1A1A1B] z-20\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white/50 rounded-full\"></div></div><div class=\"absolute -top-3 -right-4 w-16 h-6 bg-white/40 rotate-[25deg] border border-foreground/10 z-20 backdrop-blur-sm\"></div><h3 class=\"font-hand text-4xl md:text-5xl font-bold leading-tight mb-6\">No prior experience required!</h3><div class=\"font-heading font-bold text-2xl text-foreground/90\">Only <span class=\"text-sw-blue bg-white px-2 py-0.5 rounded-md border-2 border-foreground inline-block -rotate-2\">good vibes</span> and a lot of fun!</div><svg class=\"absolute -bottom-6 -left-6 text-sw-blue w-16 h-16\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M50 10 L60 40 L90 50 L60 60 L50 90 L40 60 L10 50 L40 40 Z\" fill=\"currentColor\"></path></svg></div><div class=\"absolute -bottom-10 right-10 hidden md:block\"><svg width=\"80\" height=\"80\" viewBox=\"0 0 100 100\" fill=\"none\"><path d=\"M10 90 C 20 50, 80 80, 80 20\" stroke=\"#124F6B\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\" stroke-dasharray=\"8 8\"></path><path d=\"M60 30 L80 20 L90 40\" stroke=\"#124F6B\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg></div></div></div></section><section class=\"w-full bg-[#fcfcfc] py-24 md:py-32 relative overflow-hidden\"><div class=\"absolute inset-0 pointer-events-none overflow-hidden flex items-center justify-center z-0\"><div class=\"absolute inset-0 bg-[radial-gradient(#1A1A1B_1px,transparent_1px)] [background-size:40px_40px] opacity-[0.03] [mask-image:radial-gradient(ellipse_at_center,black_40%,transparent_70%)]\"></div><div class=\"absolute top-[10%] left-[5%] text-sw-blue/10 animate-float-slow hidden md:block\"><svg width=\"120\" height=\"120\" viewBox=\"0 0 100 100\" fill=\"currentColor\"><path d=\"M45.7,96.5c-24.6,0-44.5-19.9-44.5-44.5S21.1,7.5,45.7,7.5s44.5,19.9,44.5,44.5S70.3,96.5,45.7,96.5z\"></path></svg></div><div class=\"absolute top-[20%] right-[10%] text-[#FFD166]/20 animate-float-delayed\"><svg width=\"80\" height=\"80\" viewBox=\"0 0 100 100\" fill=\"currentColor\" class=\"animate-spin-slow origin-center\"><polygon points=\"50,15 90,85 10,85\" stroke-linejoin=\"round\"></polygon></svg></div><div class=\"absolute top-[45%] left-[10%] text-[#EF476F]/15 animate-pulse-slow hidden lg:block\"><svg width=\"160\" height=\"160\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\"><circle cx=\"50\" cy=\"50\" r=\"40\" stroke-dasharray=\"8 8\"></circle></svg></div><div class=\"absolute top-[65%] right-[5%] text-[#06D6A0]/20 animate-float-medium\"><svg width=\"90\" height=\"90\" viewBox=\"0 0 100 100\" fill=\"currentColor\" class=\"rotate-12\"><rect x=\"25\" y=\"25\" width=\"50\" height=\"50\" rx=\"8\"></rect></svg></div><div class=\"absolute bottom-[10%] left-[15%] text-sw-navy/10 animate-float-fast\"><svg width=\"70\" height=\"70\" viewBox=\"0 0 100 100\" fill=\"currentColor\" class=\"animate-spin-slow origin-center\"><path d=\"M40,10 h20 v30 h30 v20 h-30 v30 h-20 v-30 h-30 v-20 h30 z\"></path></svg></div><div class=\"absolute bottom-[25%] right-[15%] text-foreground/10 animate-float-slow hidden md:block\"><svg width=\"140\" height=\"140\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\"><path d=\"M10,40 Q25,10 50,40 T90,40\" stroke-linecap=\"round\"></path><path d=\"M10,60 Q25,30 50,60 T90,60\" stroke-linecap=\"round\"></path></svg></div></div><div class=\"max-w-6xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-24 relative\"><h2 class=\"font-heading font-bold text-5xl md:text-7xl mb-4 relative inline-block\">HOW IT WORKS<svg class=\"absolute -bottom-6 left-0 w-full h-8 text-sw-blue\" viewBox=\"0 0 300 20\" fill=\"none\" preserveAspectRatio=\"none\"><path d=\"M0 10 Q 37.5 20 75 10 T 150 10 T 225 10 T 300 10\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\"></path></svg></h2><p class=\"font-medium text-xl text-foreground/70 max-w-2xl mx-auto mt-8\">From meeting strangers on Friday to pitching a startup together on Sunday.</p></div><div class=\"relative max-w-5xl mx-auto\"><div class=\"absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-1 hidden md:block z-0\"><svg width=\"10\" height=\"100%\" viewBox=\"0 0 10 100%\" preserveAspectRatio=\"none\" fill=\"none\"><line x1=\"5\" y1=\"0\" x2=\"5\" y2=\"100%\" stroke=\"#1A1A1B\" stroke-width=\"4\" stroke-dasharray=\"12 12\" stroke-linecap=\"round\"></line></svg></div><div class=\"space-y-12 md:space-y-0 relative z-10\"><div class=\"flex flex-col md:flex-row items-center w-full \"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">01</span></div><div class=\"w-full md:w-1/2 md:pl-16 lg:pl-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-[#FFD166] text-foreground\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->01</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Connect &amp; Network</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">Meet your future co-founders and teammates. It all starts with getting to know the diverse group of developers, designers, and enthusiasts who are ready to build.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Icebreakers</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Networking</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Team Formation</span></div></div></div></div><div class=\"flex flex-col md:flex-row items-center w-full md:flex-row-reverse\"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">02</span></div><div class=\"w-full md:w-1/2 md:pr-16 lg:pr-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-sw-blue-washed text-foreground\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M3 11l18-5v12L3 14v-3z\"></path><path d=\"M11.6 16.8a3 3 0 1 1-5.8-1.6\"></path></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->02</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Pitch Your Idea</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">Have a spark of inspiration? You have 60 seconds to pitch your idea to the crowd. No slides, just you and your vision. Not pitching? Vote for your favorites!</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">60s Pitch</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Voting</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Selection</span></div></div></div></div><div class=\"flex flex-col md:flex-row items-center w-full \"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">03</span></div><div class=\"w-full md:w-1/2 md:pl-16 lg:pl-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-[#EF476F] text-white\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"></path><polyline points=\"14 2 14 8 20 8\"></polyline><path d=\"M8 13h2\"></path><path d=\"M8 17h2\"></path><path d=\"M14 13h2\"></path><path d=\"M14 17h2\"></path></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->03</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Form A Team</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">The top voted ideas form teams. Find the skills you need or join a project that inspires you. This is where the magic of collaboration begins.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Skill Matching</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Role Assignment</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Brainstorming</span></div></div></div></div><div class=\"flex flex-col md:flex-row items-center w-full md:flex-row-reverse\"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">04</span></div><div class=\"w-full md:w-1/2 md:pr-16 lg:pr-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-sw-blue text-white\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"></rect><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"></line><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"></line></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->04</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Build MVP</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">Roll up your sleeves. It&#x27;s time to turn concepts into prototypes. Work with your team to build a Minimum Viable Product that demonstrates your core value.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Prototyping</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Coding</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Designing</span></div></div></div></div><div class=\"flex flex-col md:flex-row items-center w-full \"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">05</span></div><div class=\"w-full md:w-1/2 md:pl-16 lg:pl-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-white text-foreground\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><circle cx=\"11\" cy=\"11\" r=\"8\"></circle><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"></line></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->05</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Validate &amp; Pivot</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">Get out of the building (literally or virtually)! Talk to real customers, validate your assumptions, and pivot if necessary. Mentors will guide you through the chaos.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Customer Validation</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Mentorship</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Iteration</span></div></div></div></div><div class=\"flex flex-col md:flex-row items-center w-full md:flex-row-reverse\"><div class=\"hidden md:block md:w-1/2\"></div><div class=\"md:absolute left-1/2 md:-translate-x-1/2 flex items-center justify-center w-16 h-16 rounded-full bg-white doodle-border doodle-shadow z-20 mb-6 md:mb-0 rotate-[-5deg] group-hover:rotate-0 transition-transform\"><span class=\"font-heading font-black text-2xl\">06</span></div><div class=\"w-full md:w-1/2 md:pr-16 lg:pr-24\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-8 relative group transition-transform duration-300 bg-[#06D6A0] text-foreground\"><div class=\"absolute top-6 right-6 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\"></path><path d=\"M4 22h16\"></path><path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\"></path><path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\"></path><path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\"></path></svg></div><span class=\"font-hand text-xl opacity-80 mb-2 block\">Step <!-- -->06</span><h3 class=\"font-heading font-bold text-3xl mb-4 leading-tight\">Demo Day</h3><p class=\"font-medium mb-8 leading-relaxed opacity-90\">The grand finale. Pitch your startup to a panel of judges and the community. Celebrate what you&#x27;ve built in just 54 hours and launch your startup journey.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Final Pitch</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Judging</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Celebration</span></div></div></div></div></div></div><div class=\"flex justify-center mt-20\"><div class=\"relative\"><span class=\"font-hand text-2xl text-sw-navy absolute -left-32 top-4 -rotate-12\">And then...</span><svg width=\"40\" height=\"60\" viewBox=\"0 0 40 60\" fill=\"none\"><path d=\"M20 0 L20 50 M10 40 L20 55 L30 40\" stroke=\"#1A1A1B\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"></path></svg></div></div></div></section><section class=\"w-full bg-white py-24 md:py-32 relative overflow-hidden border-y-[3px] border-foreground\"><div class=\"max-w-7xl mx-auto px-6 relative z-10 flex flex-col lg:flex-row gap-16\"><div class=\"lg:w-1/3 flex flex-col items-start lg:sticky lg:top-32 h-fit\"><h2 class=\"font-heading font-black text-6xl md:text-7xl lg:text-[7rem] leading-[1] uppercase tracking-tighter mb-8\">Why<br/><span class=\"text-sw-blue\">even</span><br/>join?</h2><p class=\"font-medium text-xl text-foreground/80 leading-relaxed mb-8 max-w-[400px]\">Gain access to Romania&#x27;s most accomplished startup mentors, seasoned investors, and industry leaders who are genuinely invested in your success. These experts have navigated the startup landscape and are ready to share their hard-won insights.</p><svg width=\"60\" height=\"60\" viewBox=\"0 0 100 100\" fill=\"none\" class=\"hidden lg:block text-sw-navy mt-4\"><path d=\"M10 20 C 30 10, 80 40, 90 80 M70 80 L90 80 L80 60\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg></div><div class=\"lg:w-2/3 grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16 mt-8 lg:mt-0 pt-8\"><div class=\"relative \"><div class=\"absolute -top-5 right-10 w-24 h-8 bg-white/60 border border-foreground/10 z-30 backdrop-blur-md shadow-sm rotate-[-10deg]\"></div><div class=\"doodle-border doodle-shadow p-4 pb-6 bg-[#FFD166] rotate-[-2deg] hover:rotate-0 transition-transform duration-300 group\"><div class=\"w-full aspect-square md:aspect-[4/3] doodle-border rounded-lg mb-6 overflow-hidden relative\"><img alt=\"Expert mentors\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fexpert-mentors.png&amp;w=3840&amp;q=75\"/></div><h3 class=\"font-heading font-bold text-3xl mb-4 text-center text-sw-navy\">Expert mentors</h3><div class=\"flex justify-center\"><a href=\"#\" class=\"font-hand text-xl border-b-2 border-transparent transition-colors flex items-center gap-2 text-sw-navy hover:border-sw-navy\">Join the next events<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></a></div></div></div><div class=\"relative \"><div class=\"absolute -top-5 left-10 w-24 h-8 bg-white/60 border border-foreground/10 z-30 backdrop-blur-md shadow-sm rotate-[15deg]\"></div><div class=\"doodle-border doodle-shadow p-4 pb-6 bg-sw-blue-washed rotate-[3deg] hover:rotate-0 transition-transform duration-300 group\"><div class=\"w-full aspect-square md:aspect-[4/3] doodle-border rounded-lg mb-6 overflow-hidden relative\"><img alt=\"Hands-on workshops\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fworkshops.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fworkshops.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fworkshops.png&amp;w=3840&amp;q=75\"/></div><h3 class=\"font-heading font-bold text-3xl mb-4 text-center text-sw-navy\">Hands-on workshops</h3><div class=\"flex justify-center\"><a href=\"#\" class=\"font-hand text-xl border-b-2 border-transparent transition-colors flex items-center gap-2 text-sw-navy hover:border-sw-navy\">Join the next events<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></a></div></div></div><div class=\"relative md:col-span-2 md:w-1/2 md:mx-auto\"><div class=\"absolute -top-5 right-10 w-24 h-8 bg-white/60 border border-foreground/10 z-30 backdrop-blur-md shadow-sm rotate-[5deg]\"></div><div class=\"doodle-border doodle-shadow p-4 pb-6 bg-[#EF476F] rotate-[-1deg] hover:rotate-0 transition-transform duration-300 group\"><div class=\"w-full aspect-square md:aspect-[4/3] doodle-border rounded-lg mb-6 overflow-hidden relative\"><img alt=\"Startup community\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fstartup-community.png&amp;w=3840&amp;q=75\"/></div><h3 class=\"font-heading font-bold text-3xl mb-4 text-center text-white\">Startup community</h3><div class=\"flex justify-center\"><a href=\"#\" class=\"font-hand text-xl border-b-2 border-transparent transition-colors flex items-center gap-2 text-white hover:border-white\">Join the next events<svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></a></div></div><div class=\"absolute -bottom-16 -right-12 w-32 h-32 -z-10 opacity-80 pointer-events-none hidden md:block\"><svg viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"50\" cy=\"40\" r=\"15\" fill=\"#fff\"></circle><path d=\"M35 40 C 35 20, 65 20, 65 40\" fill=\"none\"></path><circle cx=\"43\" cy=\"38\" r=\"2\" fill=\"currentColor\"></circle><circle cx=\"57\" cy=\"38\" r=\"2\" fill=\"currentColor\"></circle><path d=\"M45 45 Q 50 50 55 45\"></path><path d=\"M38 52 Q 20 70 30 90\"></path><path d=\"M62 52 Q 80 70 70 90\"></path></svg></div></div></div></div></section><section class=\"w-full bg-[#fcfcfc] py-24 md:py-32 relative overflow-hidden\"><div class=\"max-w-6xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-20 relative\"><h2 class=\"font-heading font-bold text-5xl md:text-6xl mb-6\">What our past<br/><span class=\"relative inline-block mt-2\"><span class=\"absolute -inset-2 bg-sw-blue -z-10 rotate-[-2deg] rounded-lg\"></span><span class=\"text-white relative z-10\">participants say</span></span></h2><div class=\"absolute top-0 right-10 md:right-32 text-sw-navy opacity-20 hidden sm:block\"><svg width=\"80\" height=\"80\" viewBox=\"0 0 100 100\" fill=\"currentColor\"><path d=\"M30 20 C 10 20, 10 50, 30 50 L 30 70 L 50 50 C 60 50, 50 20, 30 20 Z\"></path><path d=\"M70 20 C 50 20, 50 50, 70 50 L 70 70 L 90 50 C 100 50, 90 20, 70 20 Z\"></path></svg></div></div><div class=\"relative max-w-4xl mx-auto\"><div class=\"flex justify-between items-center mb-8 px-4\"><button class=\"cursor-pointer doodle-border doodle-shadow-active w-12 h-12 rounded-full bg-white flex items-center justify-center hover:bg-sw-blue-washed transition-colors group\" aria-label=\"Previous testimonial\"><svg class=\"w-6 h-6 group-hover:-translate-x-1 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 12H5M12 19l-7-7 7-7\"></path></svg></button><span class=\"font-hand text-xl text-foreground/60\">1<!-- --> / <!-- -->3</span><button class=\"cursor-pointer doodle-border doodle-shadow-active w-12 h-12 rounded-full bg-white flex items-center justify-center hover:bg-sw-blue-washed transition-colors group\" aria-label=\"Next testimonial\"><svg class=\"w-6 h-6 group-hover:translate-x-1 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></button></div><div class=\"relative min-h-[450px]\"><div class=\"w-full\" style=\"opacity:0;transform:translateX(-500px) translateY(-50px) scale(0.95) rotate(-5deg)\"><div class=\"doodle-border doodle-shadow rounded-[40px] p-8 md:p-12 relative min-h-[300px] flex flex-col justify-center transition-colors duration-500 bg-[#FFD166] text-foreground\"><div class=\"absolute top-6 left-6 opacity-10 pointer-events-none\"><span class=\"font-heading font-black text-9xl\">&quot;</span></div><p class=\"font-medium text-2xl md:text-3xl lg:text-4xl leading-relaxed relative z-10\">&quot;<!-- -->Startup Weekend Bucharest is the place to be if you want to squeeze 3 months of ideation into one weekend and if you want to find a team to build something.<!-- -->&quot;</p><div class=\"absolute -bottom-8 left-16 md:left-24 w-12 h-12 bg-[#FFD166] doodle-border border-t-0 border-l-0 transform rotate-45 transition-colors duration-500\"></div></div><div class=\"mt-12 ml-16 md:ml-24 flex items-center gap-4\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 50 50\" fill=\"none\" class=\"text-sw-navy rotate-[-30deg] -mt-6\"><path d=\"M10 10 Q 30 20 40 40\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" fill=\"none\"></path><path d=\"M30 40 L 40 40 L 40 30\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg><div><h4 class=\"font-heading font-bold text-2xl\">Andrei Scurtu</h4><span class=\"font-hand text-xl text-sw-blue block -mt-1\">Startup Weekend <!-- -->Bucharest</span></div></div></div></div></div></div></section><section class=\"w-full bg-white py-24 md:py-32 relative\"><div class=\"max-w-4xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-16 relative\"><h2 class=\"font-heading font-black text-5xl md:text-7xl\">FAQ</h2><svg class=\"absolute -top-6 left-1/2 md:left-[60%] -translate-x-1/2 w-12 h-12 text-sw-blue rotate-12\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\"><path d=\"M40 80 Q 50 90 60 80 Q 70 70 50 40 Q 30 10 60 10 Q 80 10 80 30\"></path><circle cx=\"50\" cy=\"95\" r=\"3\" fill=\"currentColor\"></circle></svg></div><div class=\"space-y-4\"><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 doodle-shadow bg-sw-blue-washed/50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">Do I need to come with an idea?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-sw-blue text-white\"><svg class=\"w-6 h-6 transition-transform duration-300 rotate-45\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[1fr] opacity-100\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Not at all! If you have an idea, you can pitch it on Friday night. If you don&#x27;t, you can listen to others&#x27; pitches and join a team whose idea excites you.</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">Can I join without a team?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Yes, absolutely! The whole point of Friday night is to meet people, form teams around the best ideas, and start building together.</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">How much does it cost to join? What does the ticket include?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Tickets usually cover all your meals (7 meals!), snacks, endless coffee, and all the resources you need for the 54 hours. Plus, an awesome t-shirt!</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">What should I bring with me?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Bring your laptop, charger, notebook, pen, and a lot of energy. Dress comfortably—you&#x27;ll be working hard!</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">Can I join if I&#x27;m under 18?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Usually, events are 18+, but some cities might have special exceptions. Please check the specific city page or contact the local organizers.</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">Can I work on my existing startup?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">Startup Weekend is designed to build something from scratch in 54 hours. Existing businesses cannot be pitched, but you can always use the weekend to test a new spin-off idea!</p></div></div></div><div class=\"doodle-border rounded-2xl bg-[#fcfcfc] overflow-hidden transition-all duration-300 hover:bg-gray-50\"><button class=\"w-full text-left px-6 py-6 md:px-8 md:py-8 flex items-center justify-between gap-6 focus:outline-none\"><span class=\"font-heading font-bold text-2xl md:text-3xl pr-8\">How do I apply as a mentor or sponsor?</span><div class=\"cursor-pointer flex-shrink-0 w-10 h-10 rounded-full border-2 border-foreground flex items-center justify-center transition-colors bg-white text-foreground\"><svg class=\"w-6 h-6 transition-transform duration-300 \" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 5v14M5 12h14\"></path></svg></div></button><div class=\"grid transition-all duration-300 ease-in-out grid-rows-[0fr] opacity-0\"><div class=\"overflow-hidden\"><p class=\"font-medium text-lg text-foreground/80 leading-relaxed px-6 pb-6 md:px-8 md:pb-8 pt-0\">We love our supporters! You can apply directly through the &#x27;Contact us&#x27; button at the bottom of the page.</p></div></div></div></div></div></section><section class=\"w-full relative bg-white pt-10\"><div class=\"bg-sw-blue rounded-t-[3rem] md:rounded-t-[5rem] px-6 py-24 md:py-32 relative overflow-hidden border-t-[3px] border-foreground\"><div class=\"max-w-4xl mx-auto text-center relative z-10 text-white flex flex-col items-center\"><h2 class=\"font-heading font-black text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight mb-8\">YOUR STARTUP<br/>STARTS HERE.</h2><p class=\"font-medium text-xl md:text-2xl text-white/90 leading-relaxed max-w-2xl\">At Startup Weekend, developers, designers, marketers, and future founders come together to build something real. Pitch on Friday, build all weekend, and present your startup on Sunday.</p></div></div></section><footer class=\"w-full bg-background border-t-[4px] border-foreground relative mt-24 overflow-hidden z-10 flex flex-col\"><div class=\"w-full bg-[#FEF9C3] border-b-[4px] border-foreground py-4 -rotate-1 scale-[1.05] origin-center shadow-[0_8px_0px_rgba(26,26,27,1)] relative z-20 flex items-center\"><div class=\"flex w-fit animate-marquee\"><div class=\"flex whitespace-nowrap\"><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span></div><div class=\"flex whitespace-nowrap\" aria-hidden=\"true\"><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span></div></div></div><div class=\"max-w-7xl mx-auto px-6 py-24 md:py-32 w-full\"><div class=\"flex flex-col md:flex-row gap-20 md:gap-16 justify-between items-start\"><div class=\"flex-1 max-w-xl\"><h2 class=\"font-heading font-black text-[5.5rem] md:text-[7rem] leading-[0.85] tracking-tighter uppercase relative\"><span class=\"block mb-2\">SW</span><span class=\"block text-white relative z-10 -rotate-2\" style=\"text-shadow:-3px -3px 0 #1A1A1B, 3px -3px 0 #1A1A1B, -3px 3px 0 #1A1A1B, 3px 3px 0 #1A1A1B, 8px 8px 0 #1A1A1B\">ROMANIA</span><div class=\"absolute top-[40%] left-[-10%] w-[110%] h-[35%] bg-sw-blue-washed -z-10 -rotate-2 rounded-full hidden md:block\"></div></h2><p class=\"font-hand text-3xl md:text-4xl text-foreground font-bold mt-12 md:mt-16 -rotate-2 max-w-sm leading-relaxed\">54 hours to build a startup. No fluff, just makers.</p><div class=\"mt-14 flex items-center gap-6\"><a class=\"doodle-border doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading font-bold text-xl md:text-2xl px-8 py-4 rounded-xl cursor-pointer inline-block -rotate-2 hover:rotate-0 transition-all\" href=\"/host\">Host an event</a><svg class=\"hidden md:block w-16 h-16 text-foreground -rotate-[30deg] scale-x-[-1]\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M90 50 L10 50 M30 30 L10 50 L30 70\"></path></svg></div></div><div class=\"flex flex-wrap sm:flex-nowrap gap-16 md:gap-32 lg:gap-40 md:pt-10\"><div class=\"flex flex-col gap-6 w-1/2 sm: