ansition-transform inline-block\" href=\"/mentors\"><span class=\"relative z-10\">Mentors</span><svg class=\"absolute -bottom-2 left-0 w-full h-3 text-sw-blue opacity-0 group-hover:opacity-100 transition-opacity\" viewBox=\"0 0 100 10\" preserveAspectRatio=\"none\"><path d=\"M0 5 Q 12.5 0, 25 5 T 50 5 T 75 5 T 100 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"></path></svg></a><a class=\"relative group font-heading hover:-rotate-2 transition-transform inline-block\" href=\"/contact\"><span class=\"relative z-10\">Contact</span><svg class=\"absolute -bottom-2 left-0 w-full h-3 text-sw-blue opacity-0 group-hover:opacity-100 transition-opacity\" viewBox=\"0 0 100 10\" preserveAspectRatio=\"none\"><path d=\"M0 5 Q 12.5 0, 25 5 T 50 5 T 75 5 T 100 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"></path></svg></a><a class=\"relative font-heading text-sw-navy group inline-block\" href=\"/host\"><div class=\"absolute inset-0 bg-sw-blue-washed border-2 border-black transform rotate-2 group-hover:rotate-6 transition-transform rounded-xl\"></div><div class=\"relative px-5 py-2 border-2 border-black bg-white rounded-xl transform -rotate-1 group-hover:-rotate-2 transition-transform shadow-[4px_4px_0px_black] group-hover:shadow-[6px_6px_0px_black] font-bold flex items-center gap-2\">Host in Your City<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" class=\"absolute -top-3 -right-3 text-[#FFD700] animate-pulse-slow\"><path d=\"M12 2L15 9L22 10L17 15L18.5 22L12 18L5.5 22L7 15L2 10L9 9L12 2Z\" fill=\"currentColor\" stroke=\"black\" stroke-width=\"2\" stroke-linejoin=\"round\"></path></svg></div></a></nav><div class=\"hidden md:flex items-center gap-4 z-50\"><a class=\"doodle-border doodle-shadow doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading rounded-full cursor-pointer hidden md:block font-semibold px-6 py-2 hover:scale-105 transition-transform\" href=\"/#past-events\">Get Tickets</a></div><button class=\"md:hidden z-50 p-2 border-3 border-black rounded-xl bg-[#FEF9C3] shadow-[4px_4px_0px_black] active:shadow-[0px_0px_0px_black] active:translate-x-[4px] active:translate-y-[4px] transition-all\"><svg class=\"w-7 h-7\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></header><main class=\"flex-1 w-full max-w-7xl mx-auto px-6 py-16 md:py-24\"><section class=\"w-full relative\" style=\"opacity:0\"><div class=\"text-center mb-16 md:mb-20\" style=\"opacity:0;transform:translateY(20px)\"><h1 class=\"font-heading font-bold text-5xl md:text-7xl leading-[1.1] tracking-tight\">Get in Touch</h1><p class=\"mt-6 font-medium text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto leading-relaxed\">Have questions about Startup Weekend Romania? Want to partner with us or just say hello? We&#x27;d love to hear from you!</p></div><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"order-2 lg:order-1\"><div class=\"bg-white text-foreground p-8 rounded-3xl border-4 border-foreground shadow-[8px_8px_0px_0px_rgba(26,26,27,1)]\"><h2 class=\"font-heading font-bold text-2xl md:text-3xl mb-6\">Send us a message</h2><form class=\"space-y-6\"><div><label for=\"name\" class=\"block font-bold mb-2\">Full Name</label><input id=\"name\" type=\"text\" placeholder=\"Enter your full name\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div><label for=\"email\" class=\"block font-bold mb-2\">Email Address</label><input id=\"email\" type=\"email\" placeholder=\"your.email@example.com\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div><label for=\"subject\" class=\"block font-bold mb-2\">Subject</label><input id=\"subject\" type=\"text\" placeholder=\"What is this about?\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div><label for=\"message\" class=\"block font-bold mb-2\">Message</label><textarea id=\"message\" placeholder=\"Your message here...\" rows=\"5\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent resize-none\"></textarea></div><div class=\"pt-2\"><button class=\"doodle-border doodle-shadow doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading rounded-full cursor-pointer font-bold text-xl px-10 py-5 inline-flex items-center gap-3 w-full justify-center\" type=\"submit\">Send Message<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></button></div></form></div></div><div class=\"order-1 lg:order-2\"><div class=\"bg-sw-blue py-12 px-8 md:px-10 rounded-3xl border-4 border-foreground shadow-[8px_8px_0px_0px_rgba(26,26,27,1)] h-full text-white relative overflow-hidden\"><div class=\"absolute top-6 right-6 text-white/20\"><svg width=\"60\" height=\"60\" viewBox=\"0 0 100 100\" fill=\"currentColor\"><path d=\"M50 0 L55 40 L100 50 L55 60 L50 100 L45 60 L0 50 L45 40 Z\"></path></svg></div><h2 class=\"font-heading font-bold text-2xl md:text-3xl mb-8 relative z-10\">Contact Info</h2><div class=\"space-y-8 relative z-10\"><div><h3 class=\"font-bold text-lg mb-2 text-[#FEF9C3]\">Email</h3><a href=\"mailto:hello@startupweekend.ro\" class=\"text-lg hover:underline\">hello@startupweekend.ro</a></div><div><h3 class=\"font-bold text-lg mb-2 text-[#FEF9C3]\">Phone</h3><a href=\"tel:+40712345678\" class=\"text-lg hover:underline\">+40 712 345 678</a></div