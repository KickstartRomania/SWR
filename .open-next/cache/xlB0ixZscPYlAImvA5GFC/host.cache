ition-transform inline-block\" href=\"/mentors\"><span class=\"relative z-10\">Mentors</span><svg class=\"absolute -bottom-2 left-0 w-full h-3 text-sw-blue opacity-0 group-hover:opacity-100 transition-opacity\" viewBox=\"0 0 100 10\" preserveAspectRatio=\"none\"><path d=\"M0 5 Q 12.5 0, 25 5 T 50 5 T 75 5 T 100 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"></path></svg></a><a class=\"relative group font-heading hover:-rotate-2 transition-transform inline-block\" href=\"/contact\"><span class=\"relative z-10\">Contact</span><svg class=\"absolute -bottom-2 left-0 w-full h-3 text-sw-blue opacity-0 group-hover:opacity-100 transition-opacity\" viewBox=\"0 0 100 10\" preserveAspectRatio=\"none\"><path d=\"M0 5 Q 12.5 0, 25 5 T 50 5 T 75 5 T 100 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\"></path></svg></a><a class=\"relative font-heading text-sw-navy group inline-block\" href=\"/host\"><div class=\"absolute inset-0 bg-sw-blue-washed border-2 border-black transform rotate-2 group-hover:rotate-6 transition-transform rounded-xl\"></div><div class=\"relative px-5 py-2 border-2 border-black bg-white rounded-xl transform -rotate-1 group-hover:-rotate-2 transition-transform shadow-[4px_4px_0px_black] group-hover:shadow-[6px_6px_0px_black] font-bold flex items-center gap-2\">Host in Your City<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" class=\"absolute -top-3 -right-3 text-[#FFD700] animate-pulse-slow\"><path d=\"M12 2L15 9L22 10L17 15L18.5 22L12 18L5.5 22L7 15L2 10L9 9L12 2Z\" fill=\"currentColor\" stroke=\"black\" stroke-width=\"2\" stroke-linejoin=\"round\"></path></svg></div></a></nav><div class=\"hidden md:flex items-center gap-4 z-50\"><a class=\"doodle-border doodle-shadow doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading rounded-full cursor-pointer hidden md:block font-semibold px-6 py-2 hover:scale-105 transition-transform\" href=\"/#past-events\">Get Tickets</a></div><button class=\"md:hidden z-50 p-2 border-3 border-black rounded-xl bg-[#FEF9C3] shadow-[4px_4px_0px_black] active:shadow-[0px_0px_0px_black] active:translate-x-[4px] active:translate-y-[4px] transition-all\"><svg class=\"w-7 h-7\" fill=\"none\" stroke=\"currentColor\" stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"3\" viewBox=\"0 0 24 24\"><path d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></header><main class=\"flex-1 w-full max-w-5xl mx-auto px-6 py-16 md:py-24\"><section class=\"w-full relative\" style=\"opacity:0\"><div class=\"text-center mb-16 md:mb-20\" style=\"opacity:0;transform:translateY(20px)\"><h1 class=\"font-heading font-bold text-5xl md:text-7xl leading-[1.1] tracking-tight\">Host Startup Weekend<br/><span class=\"relative inline-block px-[0.15em]\"><span class=\"absolute inset-0 bg-sw-blue -z-10 rounded-lg\" style=\"transform:rotate(-2deg)\"></span><span class=\"relative text-white\">in Your City</span></span></h1><p class=\"mt-8 font-medium text-lg md:text-xl text-foreground/80 max-w-2xl mx-auto leading-relaxed\">Bring the energy of entrepreneurship to your community. As a facilitator, you&#x27;ll lead an incredible weekend where ideas become reality, connections are made, and startups are born.</p></div><div class=\"relative\" style=\"opacity:0;transform:translateY(20px)\"><h2 class=\"font-heading font-bold text-2xl md:text-3xl mb-8\">Facilitator Application</h2><form class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 auto-rows-auto\"><div class=\"doodle-border doodle-shadow rounded-2xl p-6 bg-[#FFD166] rotate-[-1deg] hover:rotate-0 transition-transform\"><label for=\"fullName\" class=\"block font-heading font-bold text-lg mb-2\">Full Name <span class=\"text-[#EF476F]\">*</span></label><input id=\"fullName\" type=\"text\" placeholder=\"John Doe\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div class=\"doodle-border doodle-shadow rounded-2xl p-6 bg-white rotate-[1deg] hover:rotate-0 transition-transform\"><label for=\"email\" class=\"block font-heading font-bold text-lg mb-2\">Email Address <span class=\"text-[#EF476F]\">*</span></label><input id=\"email\" type=\"email\" placeholder=\"john@example.com\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div class=\"doodle-border doodle-shadow rounded-2xl p-6 bg-sw-blue-washed rotate-[2deg] hover:rotate-0 transition-transform\"><label for=\"phone\" class=\"block font-heading font-bold text-lg mb-2\">Phone <span class=\"text-[#EF476F]\">*</span></label><input id=\"phone\" type=\"tel\" placeholder=\"+40 123...\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div class=\"doodle-border doodle-shadow rounded-2xl p-6 bg-white rotate-[-2deg] hover:rotate-0 transition-transform\"><label for=\"city\" class=\"block font-heading font-bold text-lg mb-2\">City <span class=\"text-[#EF476F]\">*</span></label><input id=\"city\" type=\"text\" placeholder=\"Cluj-Napoca\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent\"/></div><div class=\"md:col-span-2 doodle-border doodle-shadow rounded-2xl p-6 bg-sw-blue text-white rotate-[1deg] hover:rotate-0 transition-transform relative overflow-hidden\"><div class=\"absolute top-4 right-4 text-white/20\"><svg width=\"40\" height=\"40\" viewBox=\"0 0 100 100\" fill=\"currentColor\"><path d=\"M50 0 L55 40 L100 50 L55 60 L50 100 L45 60 L0 50 L45 40 Z\"></path></svg></div><h3 class=\"font-heading font-bold text-xl mb-4 relative z-10\">Commitment</h3><div class=\"space-y-4 relative z-10\"><div><label id=\"commitment-label\" for=\"commitment\" class=\"block font-bold mb-2 text-white/90\">Can you commit to 54 hours? <span class=\"text-[#FFD166]\">*</span></label><div class=\"relative \"><input type=\"hidden\" id=\"commitment\" required=\"\" readOnly=\"\" name=\"commitment\" value=\"\"/><button type=\"button\" aria-haspopup=\"listbox\" aria-expanded=\"false\" aria-labelledby=\"commitment-label\" class=\"\n          w-full px-4 py-3 rounded-xl font-medium text-left\n          flex items-center justify-between gap-3\n          cursor-pointer transition-all duration-200\n          border-2 focus:outline-none focus:ring-2 focus:ring-sw-blue focus:ring-offset-2\n          doodle-border doodle-shadow bg-white text-foreground border-foreground hover:border-sw-blue hover:shadow-[4px_4px_0px_var(--foreground)]\n        \"><span class=\"text-foreground/60\">Select an option</span><span class=\"inline-block transition-transform duration-200 \"><svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 9l-7 7-7-7\"></path></svg></span></button></div></div><div class=\"grid grid-cols-1 sm:grid-cols-2 gap-4\"><div><label for=\"preferredDate\" class=\"block font-bold mb-2 text-white/90\">Preferred Event Date</label><input id=\"preferredDate\" type=\"date\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent bg-white text-foreground\"/></div><div><label for=\"linkedin\" class=\"block font-bold mb-2 text-white/90\">LinkedIn Profile</label><input id=\"linkedin\" type=\"url\" placeholder=\"https://linkedin.com/in/...\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent bg-white text-foreground\"/></div></div></div></div><div class=\"md:col-span-2 doodle-border doodle-shadow rounded-2xl p-6 bg-white rotate-[-1deg] hover:rotate-0 transition-transform\"><label for=\"professionalBackground\" class=\"block font-heading font-bold text-lg mb-2\">Professional Background <span class=\"text-[#EF476F]\">*</span></label><textarea id=\"professionalBackground\" placeholder=\"Tell us about your professional experience...\" rows=\"5\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent resize-none\"></textarea></div><div class=\"md:col-span-2 doodle-border doodle-shadow rounded-2xl p-6 bg-[#FEF9C3] rotate-[2deg] hover:rotate-0 transition-transform\"><label for=\"eventExperience\" class=\"block font-heading font-bold text-lg mb-2\">Previous Event Organization Experience</label><textarea id=\"eventExperience\" placeholder=\"Have you organized events before?\" rows=\"4\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent resize-none\"></textarea></div><div class=\"md:col-span-2 doodle-border doodle-shadow rounded-2xl p-6 bg-sw-blue-washed rotate-[-2deg] hover:rotate-0 transition-transform\"><label for=\"whyHost\" class=\"block font-heading font-bold text-lg mb-2\">Why host in your city? <span class=\"text-[#EF476F]\">*</span></label><textarea id=\"whyHost\" placeholder=\"Share your vision and motivation...\" rows=\"5\" required=\"\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent resize-none\"></textarea></div><div class=\"md:col-span-2 lg:col-span-4 doodle-border doodle-shadow rounded-2xl p-6 bg-white rotate-[1deg] hover:rotate-0 transition-transform\"><label for=\"comments\" class=\"block font-heading font-bold text-lg mb-2\">Additional Comments</label><textarea id=\"comments\" placeholder=\"Anything else you&#x27;d like us to know...\" rows=\"4\" class=\"w-full px-4 py-3 rounded-xl border-2 border-foreground focus:outline-none focus:ring-2 focus:ring-sw-blue focus:border-transparent resize-none\"></textarea></div><div class=\"md:col-span-2 lg:col-span-4 pt-4\"><button class=\"doodle-border doodle-shadow doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading rounded-full cursor-pointer font-bold text-xl px-10 py-5 inline-flex items-center gap-3 w-full justify-center md:max-w-md mx-auto block\" type=\"submit\">Submit Application<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></button></div></form></div></section></main><section class=\"w-full relative bg-white pt-10\"><div class=\"bg-sw-blue rounded-t-[3rem] md:rounded-t-[5rem] px-6 py-24 md:py-32 relative overflow-hidden border-t-[3px] border-foreground\"><div class=\"max-w-4xl mx-auto text-center relative z-10 text-white flex flex-col items-center\"><h2 class=\"font-heading font-black text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tight mb-8\">YOUR STARTUP<br/>STARTS HERE.</h2><p class=\"font-medium text-xl md:text-2xl text-white/90 leading-relaxed max-w-2xl\">At Startup Weekend, developers, designers, marketers, and future founders come together to build something real. Pitch on Friday, build all weekend, and present your startup on Sunday.</p></div></div></section><footer class=\"w-full bg-background border-t-[4px] border-foreground relative mt-24 overflow-hidden z-10 flex flex-col\"><div class=\"w-full bg-[#FEF9C3] border-b-[4px] border-foreground py-4 -rotate-1 scale-[1.05] origin-center shadow-[0_8px_0px_rgba(26,26,27,1)] relative z-20 flex items-center\"><div class=\"flex w-fit animate-marquee\"><div class=\"flex whitespace-nowrap\"><span class=\"mx-4 font-heading font-black text-foreground text-3xl md:text-4xl uppercase tracking-widest\">BUILD SOMETHING REAL • STARTUP WEEKEND • </span><span class=\"mx-4 font-heading font-black text-foregrou