th=\"60\" height=\"60\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M50 10 L50 90 M10 50 L90 50 M25 25 L75 75 M25 75 L75 25\"></path></svg></div><div class=\"absolute top-6 left-4 md:top-24 md:left-12 w-20 h-20 md:w-50 md:h-50 flex items-center justify-center z-20 overflow-hidden pointer-events-none\" style=\"opacity:0;transform:scale(0) rotate(-45deg)\"><img alt=\"Sticker 1\" loading=\"lazy\" width=\"250\" height=\"100\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain w-full h-full\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fstickers%2Fclimb.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fstickers%2Fclimb.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fstickers%2Fclimb.png&amp;w=640&amp;q=75\"/></div><div class=\"absolute top-6 right-4 md:top-32 md:right-16 w-20 h-20 md:w-40 md:h-40 flex items-center justify-center z-20 pointer-events-none\" style=\"opacity:0;transform:scale(0) rotate(45deg)\"><img alt=\"Sticker 1\" loading=\"lazy\" width=\"250\" height=\"100\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain w-full h-full\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fstickers%2Fpbp.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fstickers%2Fpbp.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fstickers%2Fpbp.png&amp;w=640&amp;q=75\"/></div><div class=\"absolute bottom-6 left-4 md:bottom-20 md:left-24 w-20 h-20 md:w-40 md:h-40 flex items-center justify-center z-20 pointer-events-none\" style=\"opacity:0;transform:scale(0) rotate(-20deg)\"><img alt=\"Sticker 1\" loading=\"lazy\" width=\"200\" height=\"200\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain w-full h-full\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fstickers%2Fpresent-judges.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fstickers%2Fpresent-judges.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fstickers%2Fpresent-judges.png&amp;w=640&amp;q=75\"/></div><div class=\"absolute bottom-6 right-4 md:bottom-24 md:right-40 w-20 h-20 md:w-50 md:h-40 flex items-center justify-center z-20 pointer-events-none\" style=\"opacity:0;transform:scale(0) rotate(30deg)\"><img alt=\"Sticker 1\" loading=\"lazy\" width=\"250\" height=\"100\" decoding=\"async\" data-nimg=\"1\" class=\"object-contain w-full h-full\" style=\"color:transparent\" srcSet=\"/_next/image?url=%2Fstickers%2Fno-exp.png&amp;w=256&amp;q=75 1x, /_next/image?url=%2Fstickers%2Fno-exp.png&amp;w=640&amp;q=75 2x\" src=\"/_next/image?url=%2Fstickers%2Fno-exp.png&amp;w=640&amp;q=75\"/></div><div class=\"flex flex-col items-center z-10 w-full\" style=\"opacity:0\"><span class=\"font-hand text-2xl md:text-3xl text-sw-blue mb-4 rotate-[-2deg]\" style=\"opacity:0;transform:translateY(20px)\">Next event: 15-17 Nov</span><h1 class=\"font-heading font-bold text-5xl md:text-7xl lg:text-8xl leading-[1.1] md:leading-[1.1] tracking-tight max-w-4xl relative z-10\"><div class=\"inline-block\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px)\">STARTUP WEEKEND</div><br/><div class=\"inline-block relative mt-2 md:mt-4\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px)\"><span class=\"relative inline-block px-[0.2em] z-10 whitespace-nowrap\"><span class=\"absolute top-[5%] left-[-2.5%] w-[105%] h-[100%] bg-sw-blue -z-10 rounded-[8px_12px_10px_8px]\" style=\"transform:scaleX(0) rotate(-2deg);transform-origin:0% 50% 0\"></span><span class=\"inline-block\" style=\"color:#1A1A1B\">TÂRGU JIU</span></span></div></h1><div class=\"absolute top-[80%] -left-[10%] mt-6 hidden lg:block z-10\"><svg class=\"rotate-[-10deg]\" width=\"141\" height=\"172\" viewBox=\"0 0 141 172\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M10 10 C 50 100, 100 120, 160 160\" stroke=\"#E1AD01\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-dasharray=\"0 1\" pathLength=\"1\" stroke-dashoffset=\"0\"></path></svg></div><p class=\"mt-8 font-medium text-lg md:text-xl text-foreground/80 max-w-2xl leading-relaxed\" style=\"opacity:0;filter:blur(8px);transform:translateY(30px)\">Build a startup in one weekend.</p><div class=\"mt-12 relative\" style=\"opacity:0;transform:translateY(20px)\"><button class=\"doodle-border doodle-shadow doodle-shadow-hover doodle-shadow-active bg-sw-blue text-white font-heading rounded-full cursor-pointer font-bold text-xl px-10 py-5 inline-flex items-center gap-3\">Secure your spot!<svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg></button></div><div class=\"mt-20 w-full max-w-md mx-auto opacity-50\" style=\"opacity:0;transform:translateY(20px)\"><svg width=\"100%\" height=\"20\" viewBox=\"0 0 400 20\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\" preserveAspectRatio=\"none\"><path d=\"M0 10 Q 50 20 100 10 T 200 10 T 300 10 T 400 10\" stroke=\"#1A1A1B\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\" opacity=\"0\" pathLength=\"1\" stroke-dashoffset=\"0\" stroke-dasharray=\"0 1\"></path></svg></div></div></section><section class=\"w-full max-w-7xl mx-auto px-6 py-24 md:py-32 relative\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div class=\"flex flex-col relative z-10\"><div class=\"inline-block mb-4\"><span class=\"font-hand text-xl md:text-2xl text-sw-blue border-2 border-foreground rounded-full px-4 py-1 rotate-[-3deg] inline-block bg-white doodle-shadow-active\">The big question</span></div><h2 class=\"font-heading font-bold text-5xl md:text-6xl lg:text-7xl leading-tight mb-8\">What is <br/><span class=\"text-sw-blue\">Startup Weekend</span><br/>Târgu Jiu?</h2><p class=\"font-medium text-lg md:text-xl text-foreground/80 leading-relaxed mb-10 max-w-lg\">Startup Weekend Târgu Jiu is a high-energy weekend hackathon where builders, creatives, and future founders come together to launch real startup ideas, from pitch to prototype.</p></div><div class=\"relative h-full min-h-[400px] flex items-center justify-center lg:justify-end\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-sw-blue-washed rounded-full blur-3xl opacity-50 -z-10\"></div><div class=\"relative w-full max-w-md doodle-border doodle-shadow bg-[#FFD166] rounded-xl p-10 rotate-[4deg] transform hover:rotate-0 transition-transform duration-500 z-10\"><div class=\"absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-sw-navy rounded-full border-2 border-foreground shadow-[2px_2px_0px_#1A1A1B] z-20\"><div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-2 h-2 bg-white/50 rounded-full\"></div></div><div class=\"absolute -top-3 -right-4 w-16 h-6 bg-white/40 rotate-[25deg] border border-foreground/10 z-20 backdrop-blur-sm\"></div><h3 class=\"font-hand text-4xl md:text-5xl font-bold leading-tight mb-6\">Start building, not planning.</h3><div class=\"font-heading font-bold text-2xl text-foreground/90 leading-tight\">Turn your idea into a real <span class=\"text-sw-blue bg-white px-2 py-0.5 rounded-md border-2 border-foreground inline-block -rotate-2\">startup</span>.</div><svg class=\"absolute -bottom-6 -left-6 text-sw-blue w-16 h-16\" viewBox=\"0 0 100 100\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M50 10 L60 40 L90 50 L60 60 L50 90 L40 60 L10 50 L40 40 Z\" fill=\"currentColor\"></path></svg></div><div class=\"absolute -bottom-10 right-10 hidden md:block\"><svg width=\"80\" height=\"80\" viewBox=\"0 0 100 100\" fill=\"none\"><path d=\"M10 90 C 20 50, 80 80, 80 20\" stroke=\"#124F6B\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\" stroke-dasharray=\"8 8\"></path><path d=\"M60 30 L80 20 L90 40\" stroke=\"#124F6B\" stroke-width=\"4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" fill=\"none\"></path></svg></div></div></div></section><section class=\"w-full bg-[#fcfcfc] py-24 md:py-32 relative overflow-hidden\"><div class=\"max-w-6xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-20 relative\"><h2 class=\"font-heading font-bold text-5xl md:text-7xl mb-4 relative inline-block\">HOW IT WORKS<svg class=\"absolute -bottom-6 left-0 w-full h-8 text-sw-blue\" viewBox=\"0 0 300 20\" fill=\"none\" preserveAspectRatio=\"none\"><path d=\"M0 10 Q 37.5 20 75 10 T 150 10 T 225 10 T 300 10\" stroke=\"currentColor\" stroke-width=\"4\" stroke-linecap=\"round\" fill=\"none\"></path></svg></h2><p class=\"font-medium text-xl text-foreground/70 max-w-2xl mx-auto mt-8\">From meeting strangers on Friday to pitching a startup together on Sunday.</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6\"><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-[#FFD166] text-foreground\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2\"></path><circle cx=\"9\" cy=\"7\" r=\"4\"></circle><path d=\"M23 21v-2a4 4 0 0 0-3-3.87\"></path><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"></path></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->01</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Connect &amp; Network</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Meet your future co-founders. Connect with developers, designers, and enthusiasts.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Icebreakers</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Networking</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Team Formation</span></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-sw-blue-washed text-foreground\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M3 11l18-5v12L3 14v-3z\"></path><path d=\"M11.6 16.8a3 3 0 1 1-5.8-1.6\"></path></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->02</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Pitch Your Idea</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Pitch your idea in 60 seconds. No slides, just your vision. Or vote for your favorites!</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">60s Pitch</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Voting</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Selection</span></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-[#EF476F] text-white\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z\"></path><polyline points=\"14 2 14 8 20 8\"></polyline><path d=\"M8 13h2\"></path><path d=\"M8 17h2\"></path><path d=\"M14 13h2\"></path><path d=\"M14 17h2\"></path></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->03</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Form A Team</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Top ideas form teams. Find the skills you need or join an inspiring project to start collaborating.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Skill Matching</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Role Assignment</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Brainstorming</span></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-sw-blue text-white\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><rect x=\"2\" y=\"3\" width=\"20\" height=\"14\" rx=\"2\" ry=\"2\"></rect><line x1=\"8\" y1=\"21\" x2=\"16\" y2=\"21\"></line><line x1=\"12\" y1=\"17\" x2=\"12\" y2=\"21\"></line></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->04</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Build MVP</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Turn concepts into prototypes. Build a Minimum Viable Product that demonstrates your core value.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Prototyping</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Coding</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Designing</span></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-white text-foreground\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><circle cx=\"11\" cy=\"11\" r=\"8\"></circle><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"></line></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->05</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Validate &amp; Pivot</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Talk to real customers, validate assumptions, and pivot if necessary. Mentors will guide you.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Customer Validation</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Mentorship</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Iteration</span></div></div></div><div style=\"opacity:0;transform:translateY(24px)\"><div class=\"doodle-border doodle-shadow-hover rounded-3xl p-7 relative group transition-transform duration-300 h-full bg-[#06D6A0] text-foreground\"><div class=\"absolute top-5 right-5 opacity-20 group-hover:scale-110 transition-transform group-hover:rotate-12\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-8 h-8\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\"></path><path d=\"M4 22h16\"></path><path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\"></path><path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\"></path><path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\"></path></svg></div><span class=\"font-hand text-lg opacity-70 mb-1 block\">Step <!-- -->06</span><h3 class=\"font-heading font-bold text-2xl mb-3 leading-tight\">Demo Day</h3><p class=\"font-medium text-[15px] mb-6 leading-relaxed opacity-90\">Pitch to a panel of judges and the community. Celebrate what you&#x27;ve built in just 54 hours.</p><div class=\"flex flex-wrap gap-2\"><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Final Pitch</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Judging</span><span class=\"text-sm font-bold px-3 py-1 rounded-full border-2 border-current bg-white/20 backdrop-blur-sm\">Celebration</span></div></div></div></div></div></section><section class=\"w-full bg-[#fcfcfc] py-24 relative overflow-hidden\"><div class=\"max-w-4xl mx-auto px-4 sm:px-6 relative z-10\"><div class=\"bg-white rounded-r-3xl rounded-l-md border-2 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] relative overflow-hidden flex min-h-[600px]\"><div class=\"absolute left-0 top-0 bottom-0 w-8 md:w-12 bg-gray-100 border-r-2 border-black flex flex-col justify-evenly items-center py-8 z-20\"><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div><div class=\"w-4 h-4 md:w-5 md:h-5 rounded-full bg-[#fcfcfc] border-2 border-black inset-shadow\"></div></div><div class=\"absolute left-16 md:left-24 top-0 bottom-0 w-0.5 bg-red-400/60 z-10\"></div><div class=\"absolute left-[70px] md:left-[100px] top-0 bottom-0 w-0.5 bg-red-400/60 z-10\"></div><div class=\"absolute inset-0 z-0 pointer-events-none opacity-40 ml-8 md:ml-12\" style=\"background-image:repeating-linear-gradient(transparent, transparent 39px, #60a5fa 39px, #60a5fa 40px);background-position-y:40px\"></div><div class=\"flex-1 ml-8 md:ml-12 pl-12 pr-6 md:pl-20 md:pr-12 pt-16 pb-16 relative z-10\"><div class=\"text-left mb-12\"><div style=\"opacity:0;transform:translateY(10px)\"><h2 class=\"font-hand font-bold text-5xl md:text-6xl mb-2 text-sw-blue tracking-wider transform -rotate-2 inline-block\">AGENDA</h2><p class=\"font-hand text-2xl text-foreground/70 transform -rotate-1\">How things will probably work...</p></div></div><div class=\"flex flex-wrap gap-4 mb-10 border-b-2 border-black/10 pb-6\"><button class=\"px-4 py-1 font-hand text-2xl transition-colors relative text-sw-blue font-bold\" tabindex=\"0\">Friday<svg class=\"absolute -bottom-2 left-0 w-full h-2 text-yellow-400\" viewBox=\"0 0 100 20\" preserveAspectRatio=\"none\"><path d=\"M0 10 Q 50 20 100 10\" stroke=\"currentColor\" stroke-width=\"4\" fill=\"none\" stroke-linecap=\"round\"></path></svg></button><button class=\"px-4 py-1 font-hand text-2xl transition-colors relative text-foreground/60 hover:text-black\" tabindex=\"0\">Saturday</button><button class=\"px-4 py-1 font-hand text-2xl transition-colors relative text-foreground/60 hover:text-black\" tabindex=\"0\">Sunday</button></div><div class=\"space-y-8\"><div class=\"space-y-8\" style=\"opacity:0;transform:translateX(-10px)\"><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">17:30 - 18:00</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Registration</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Arrive at the venue and get checked in</p></div></div><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">18:00 - 18:30</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Dinner &amp; networking</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Eat food, share ideas, practice pitches, and get to know your fellow participants</p></div></div><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">18:30 - 19:00</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Welcome</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Meet our Techstars facilitator and review agenda for the weekend</p></div></div><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">19:00 - 20:00</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Pitches</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Facilitator gives a walk-through of the pitching process and then pitches begin!</p></div></div><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">20:00 - 21:00</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Vote for top pitches and form teams</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Network, share questions, vote for the top pitches and form teams</p></div></div><div class=\"flex flex-col md:flex-row gap-2 md:gap-6 group\" style=\"opacity:0;transform:translateY(10px)\"><div class=\"font-hand font-bold text-sw-blue text-xl md:w-36 pt-1 tracking-wider\">21:30 - 00:00</div><div class=\"flex-1\"><h3 class=\"font-hand font-bold text-2xl mb-1 group-hover:text-sw-blue transition-colors\">Start building!</h3><p class=\"font-hand text-xl text-foreground/80 leading-relaxed\">Set up your team workspace for the weekend and start work on the idea</p></div></div></div></div></div></div></div></section><section class=\"w-full bg-white py-24 relative overflow-hidden\"><div class=\"absolute inset-0 opacity-[0.03] pointer-events-none\" style=\"background-image:radial-gradient(#1A1A1B 2px, transparent 2px);background-size:32px 32px\"></div><div class=\"max-w-6xl mx-auto px-6 relative z-10\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><h2 class=\"font-heading font-bold text-4xl md:text-5xl mb-4 relative inline-block\">Meet your mentors<div class=\"absolute -bottom-2 left-0 w-full h-3 bg-yellow-300 -z-10 transform -rotate-2\" style=\"transform:scaleX(0);transform-origin:0% 50% 0\"></div></h2><p class=\"font-medium text-xl text-foreground/70 mt-6\">Expert guidance to help you build and validate your idea</p></div><div class=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8\"><div class=\"bg-[#fcfcfc] p-6 rounded-2xl border-2 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] flex flex-col items-center text-center transition-all duration-300 relative group cursor-pointer\" style=\"opacity:0;transform:translateY(20px) scale(0.9)\"><div class=\"absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity\"><svg width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" class=\"text-sw-blue animate-pulse-slow\"><path d=\"M12 2L15 9L22 12L15 15L12 22L9 15L2 12L9 9L12 2Z\" fill=\"currentColor\"></path></svg></div><div class=\"w-32 h-32 rounded-full overflow-hidden border-2 border-black mb-4 bg-gray-200 relative group-hover:border-sw-blue transition-colors duration-300\"><img alt=\"Valentin Albu\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover group-hover:scale-105 transition-transform duration-300\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"128px\" srcSet=\"/_next/image?url=%2Fimages%2Ftargujiu%2Fmentors%2Fvalentin-albu.png&amp;w=32&amp;q=75 32w, /_